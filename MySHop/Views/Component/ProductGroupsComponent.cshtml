@model IEnumerable<ShowGroupViewModel>

<div class="card shadow-sm" style="max-width:350px; margin:auto;">
    <div class="card-header bg-primary text-white text-center">
        دسته‌بندی‌ها
    </div>

    <table class="table table-sm table-hover mb-0 align-middle text-center">
        <thead class="table-light">
            <tr>
                <th>دسته</th>
                <th>تعداد کالا</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td>
                        <a asp-controller="Product"
                           asp-action="ShowProductByGroup"
                           asp-route-id="@cat.GruopId"
                           asp-route-name="@cat.GroupName"
                           class="text-decoration-none text-dark fw-bold">
                            @cat.GroupName
                        </a>
                    </td>

                    <td>
                        <span class="badge bg-success">
                            @cat.ProductCount
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>





